<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>资产托管AI指令清算平台 - 管理侧运营看板</title>
  <style>
    :root {
      --bg: #f4f7fb;
      --nav: #062b54;
      --nav-2: #083866;
      --brand: #d71920;
      --brand-soft: #fff1f2;
      --blue: #1677ff;
      --cyan: #11a8ff;
      --green: #16a06b;
      --orange: #f58b00;
      --purple: #7654d8;
      --red: #df1f2d;
      --text: #1d2736;
      --muted: #6f7e91;
      --line: #dfe7f1;
      --card: #ffffff;
      --shadow: 0 12px 30px rgba(17, 38, 68, 0.08);
      --radius: 8px;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: "Microsoft YaHei", "PingFang SC", Arial, sans-serif;
      font-size: 14px;
    }

    .app { min-height: 100vh; display: grid; grid-template-columns: 232px 1fr; }
    .sidebar {
      background: linear-gradient(180deg, #06284f 0%, #031c3a 100%);
      color: #fff;
      padding: 22px 16px;
      position: relative;
    }
    .logo { display: flex; align-items: center; gap: 10px; margin-bottom: 30px; font-size: 17px; font-weight: 700; }
    .logo-mark { width: 34px; height: 34px; border-radius: 8px; background: #fff; color: var(--brand); display: grid; place-items: center; font-weight: 900; }
    .nav-item { height: 46px; display: flex; align-items: center; gap: 12px; padding: 0 14px; margin: 8px 0; border-radius: 6px; color: rgba(255,255,255,.82); font-weight: 600; cursor: pointer; border: 0; width: 100%; background: transparent; font: inherit; text-align: left; }
    .nav-item.active { background: var(--brand); color: #fff; box-shadow: 0 10px 22px rgba(215,25,32,.26); }
    .nav-icon { width: 22px; text-align: center; font-size: 16px; }
    .collapse { position: absolute; bottom: 28px; left: 24px; color: rgba(255,255,255,.76); font-size: 13px; }

    .main { min-width: 980px; }
    .topbar { height: 58px; background: #fff; display: flex; align-items: center; justify-content: space-between; padding: 0 28px; border-bottom: 1px solid var(--line); }
    .crumb { display: flex; align-items: center; gap: 14px; color: var(--muted); font-size: 13px; }
    .hamburger { width: 22px; height: 16px; display: grid; gap: 4px; }
    .hamburger i { background: #6b7788; border-radius: 10px; }
    .userbar { display: flex; align-items: center; gap: 16px; }
    .team-select { border: 1px solid #ffc9ce; color: var(--brand); background: #fff8f8; height: 32px; padding: 0 12px; border-radius: 6px; font-weight: 700; }
    .bell { position: relative; font-size: 18px; }
    .badge { position: absolute; top: -8px; right: -10px; background: var(--brand); color: #fff; font-size: 10px; line-height: 16px; min-width: 16px; text-align: center; border-radius: 16px; }
    .avatar { width: 30px; height: 30px; border-radius: 50%; background: linear-gradient(135deg,#dce9ff,#8db7ff); display: grid; place-items: center; font-weight: 800; color: #235; }

    .content { padding: 18px 24px 24px; }
    .page-title { display: flex; justify-content: space-between; align-items: end; margin-bottom: 14px; }
    h1 { margin: 0; font-size: 20px; letter-spacing: 0; }
    .fresh { color: var(--muted); font-size: 12px; }

    .kpis { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 14px; margin-bottom: 14px; }
    .kpi { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 16px; min-height: 104px; box-shadow: 0 5px 16px rgba(24, 53, 90, 0.04); display: grid; grid-template-columns: 46px 1fr; gap: 12px; align-items: center; }
    .kpi-icon { width: 42px; height: 42px; border-radius: 10px; display: grid; place-items: center; color: #fff; font-size: 23px; font-weight: 800; }
    .kpi-label { color: #3d4b5f; font-size: 13px; font-weight: 700; display: flex; gap: 4px; align-items: center; }
    .kpi-value { font-size: 30px; line-height: 1.1; margin: 6px 0; font-weight: 800; }
    .kpi-sub { font-size: 12px; color: var(--muted); }
    .up { color: var(--green); font-weight: 700; }
    .down { color: var(--red); font-weight: 700; }

    .grid { display: grid; grid-template-columns: 1.08fr 1.44fr 0.62fr; gap: 14px; }
    .panel { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }
    .panel-head { height: 43px; display: flex; align-items: center; justify-content: space-between; padding: 0 16px; border-bottom: 1px solid #edf2f7; }
    .panel-title { font-weight: 800; color: #253248; }
    .more { color: var(--blue); font-size: 12px; font-weight: 700; }
    .panel-body { padding: 14px 16px; }

    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; color: #526072; font-size: 12px; font-weight: 800; padding: 8px 6px; background: #f8fafc; }
    td { padding: 10px 6px; border-bottom: 1px solid #eef3f8; font-size: 12px; vertical-align: middle; }
    tr:last-child td { border-bottom: 0; }
    .person { display: flex; align-items: center; gap: 8px; font-weight: 700; }
    .face { width: 24px; height: 24px; border-radius: 50%; background: #edf4ff; display: grid; place-items: center; color: #305b90; font-size: 12px; }
    .bar { height: 8px; background: #edf3fb; border-radius: 20px; overflow: hidden; min-width: 90px; }
    .bar span { display: block; height: 100%; background: linear-gradient(90deg, #1c7cff, #00a1ff); border-radius: 20px; }
    .load-high span { background: linear-gradient(90deg, #ff7a00, #e41d2d); }
    .tag { display: inline-flex; align-items: center; height: 22px; padding: 0 8px; border-radius: 5px; font-size: 12px; font-weight: 800; }
    .tag-blue { color: #1264d8; background: #eaf3ff; }
    .tag-red { color: var(--red); background: #fff0f1; }
    .tag-orange { color: #bd6200; background: #fff5e5; }
    .tag-green { color: var(--green); background: #e9f8f0; }
    .summary { color: #526072; font-size: 12px; display: flex; justify-content: space-between; padding-top: 8px; }
    .summary strong { color: #1e2a39; }

    .risk-table td:nth-child(1) { color: #2a3a50; font-weight: 700; }
    .deadline { color: var(--red); font-weight: 900; }
    .ok-time { color: var(--green); font-weight: 800; }

    .alert-card { height: 100%; border: 1px solid #ffb2b8; background: linear-gradient(180deg, #fff7f7, #fff); border-radius: var(--radius); padding: 18px 16px; display: flex; flex-direction: column; justify-content: space-between; }
    .alert-title { color: var(--brand); font-size: 16px; font-weight: 900; display: flex; align-items: center; gap: 8px; }
    .alert-main { margin: 12px 0; font-size: 25px; font-weight: 900; line-height: 1.45; }
    .alert-main b { color: var(--brand); font-size: 38px; padding: 0 4px; }
    .button { height: 38px; border: 1px solid var(--brand); color: var(--brand); background: #fff; border-radius: 6px; font-weight: 900; display: inline-flex; justify-content: center; align-items: center; padding: 0 16px; }
    .button.primary { background: var(--brand); color: #fff; box-shadow: 0 10px 18px rgba(215,25,32,.18); }

    .lower { display: grid; grid-template-columns: 1fr 1fr 1.18fr; gap: 14px; margin-top: 14px; }
    .notice { display: grid; gap: 9px; font-size: 12px; color: #3f4d61; }
    .notice-row { display: grid; grid-template-columns: 18px 1fr auto; gap: 8px; align-items: center; }
    .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--blue); margin-left: 5px; }
    .notice strong { color: var(--red); }
    .charts { display: grid; grid-template-columns: 1fr 148px; gap: 12px; margin-top: 14px; align-items: center; }
    .mini-row { display: grid; grid-template-columns: 58px 1fr 56px; gap: 8px; align-items: center; margin: 8px 0; font-size: 12px; }
    .donut { width: 126px; height: 126px; border-radius: 50%; background: conic-gradient(#e51f2a 0 35%, #f68b1f 35% 59%, #1677ff 59% 79%, #21a67a 79% 92%, #7654d8 92% 100%); position: relative; margin: auto; }
    .donut:after { content: ""; position: absolute; inset: 28px; background: #fff; border-radius: 50%; box-shadow: inset 0 0 0 1px #eef2f6; }
    .legend { font-size: 11px; color: #536174; display: grid; gap: 7px; }
    .legend span { display: flex; align-items: center; gap: 6px; }
    .legend i { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
    .actions { display: flex; justify-content: flex-end; gap: 10px; padding: 0 16px 15px; }

    .wide { grid-column: span 2; }
    .risk-strip { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 13px; }
    .risk-item { border: 1px solid #edf1f6; background: #fbfcff; padding: 10px; border-radius: 7px; }
    .risk-item label { display: block; color: var(--muted); font-size: 12px; margin-bottom: 4px; }
    .risk-item b { font-size: 19px; }
    .dashboard-view { display: none; }
    .dashboard-view.active { display: block; }
    .employee-layout { display: grid; grid-template-columns: 1.12fr 1.08fr 0.48fr; gap: 14px; }
    .customer-layout { display: grid; grid-template-columns: 1.18fr 1.08fr 0.46fr; gap: 14px; }
    .span-2 { grid-column: span 2; }
    .line-chart { height: 210px; border: 1px solid #eef3f8; border-radius: 7px; background:
      linear-gradient(#fff, #fff) padding-box,
      repeating-linear-gradient(to bottom, transparent 0 39px, #eef3f8 40px),
      repeating-linear-gradient(to right, transparent 0 82px, #f2f5f9 83px); position: relative; overflow: hidden; }
    .line-chart svg { position: absolute; inset: 14px 18px 28px 34px; width: calc(100% - 52px); height: calc(100% - 42px); overflow: visible; }
    .axis-labels { position: absolute; left: 36px; right: 18px; bottom: 8px; display: flex; justify-content: space-between; color: #6f7e91; font-size: 11px; }
    .stage-track { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; align-items: center; }
    .stage { position: relative; min-height: 52px; padding: 8px; border-radius: 7px; background: #f7faff; border: 1px solid #e8eef6; font-size: 12px; color: #526072; }
    .stage.done { color: var(--green); background: #effaf5; border-color: #ccebdd; }
    .stage.now { color: var(--blue); background: #edf5ff; border-color: #bfdbff; font-weight: 800; }
    .stage.block { color: var(--red); background: #fff2f3; border-color: #ffc9ce; }
    .purple-card { border-color: #a98cff; background: linear-gradient(180deg, #f8f4ff, #fff); }
    .purple-card .alert-title, .purple-card .alert-main b { color: #6d3be6; }
    .purple-card .button.primary { background: #6d3be6; border-color: #6d3be6; }

    @media (max-width: 1280px) {
      .app { grid-template-columns: 196px 1fr; }
      .kpis { grid-template-columns: repeat(3, 1fr); }
      .grid, .lower, .employee-layout, .customer-layout { grid-template-columns: 1fr; }
      .wide { grid-column: auto; }
      .span-2 { grid-column: auto; }
      .main { min-width: 0; }
    }
  </style>
</head>
